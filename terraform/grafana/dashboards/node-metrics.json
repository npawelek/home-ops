    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Combined rx+tx throughput per worker node on physical NIC (eth0/eth1). Control plane excluded.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (node) (\n  rate(node_network_receive_bytes_total{node=~\"$node\", node!~\"m1|m2|m3\", device=~\"eth0|eth1\"}[$__rate_interval])\n  + rate(node_network_transmit_bytes_total{node=~\"$node\", node!~\"m1|m2|m3\", device=~\"eth0|eth1\"}[$__rate_interval])\n)",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ],
      "title": "Network Throughput (rx+tx)",
      "type": "timeseries"
    },
