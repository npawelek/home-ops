  "liveNow": false,
  "panels": [
    {
      "description": "Request rate by API endpoint. Answers: is VictoriaMetrics receiving queries?",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (path) (rate(vm_request_duration_seconds_count{job=\"victoriametrics-server\"}[$__rate_interval]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "description": "Rate of rows inserted via remote write (from OTel collectors). Answers: how fast is data coming in?",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false},
          "unit": "rows/s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "rate(vm_rows_inserted_total{job=\"victoriametrics-server\",type=\"promremotewrite\"}[$__rate_interval])",
          "legendFormat": "Remote Write",
          "refId": "A"
        }
      ],
      "title": "Ingestion Rate",
      "type": "timeseries"
    },
    {
      "description": "HTTP error rate by response code. 0 or near-zero is healthy.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false},
          "unit": "errps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 10, "x": 0, "y": 8},
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum by (code) (rate(vm_http_request_errors_total{job=\"victoriametrics-server\"}[$__rate_interval]))",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "timeseries"
    },
    {
      "description": "Rows pending to be written to storage. Spikes indicate ingestion exceeding write capacity. Sustained high values (>100K) indicate backpressure.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false, "thresholdsStyle": {"mode": "dashed"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 100000}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 10, "x": 10, "y": 8},
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "expr": "sum(vm_pending_rows{job=\"victoriametrics-server\"})",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ],
      "title": "Pending Rows",
      "type": "timeseries"
    },
    {
      "description": "Rows pending to be written. Current value.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 100000}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 8},
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {
          "expr": "sum(vm_pending_rows{job=\"victoriametrics-server\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Pending (now)",
      "type": "stat"
    },
    {
      "description": "Storage used on Longhorn PVC. Green below 60%, yellow 60-80%, red above 80%.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 60}, {"color": "red", "value": 80}]},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 12},
