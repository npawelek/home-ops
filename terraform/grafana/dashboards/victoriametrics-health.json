          "expr": "longhorn_volume_actual_size_bytes{pvc=\"victoriametrics-data\"} / longhorn_volume_capacity_bytes{pvc=\"victoriametrics-data\"} * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Storage Used (Percent)",
      "type": "stat"
    },
