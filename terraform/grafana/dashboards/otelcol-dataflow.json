{
  "uid": "otelcol-data-flow",
  "title": "OpenTelemetry Data Flow",
  "description": "End-to-end pipeline view of traces, metrics, and logs through OTel collector receivers, processors, and exporters",
  "tags": ["otelcol", "monitoring"],
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "pod",
        "label": "Pod",
        "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
        "definition": "label_values(otelcol_process_uptime_total, pod)",
        "query": {
          "query": "label_values(otelcol_process_uptime_total, pod)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Spans Received / s",
      "description": "Total spans accepted per second across all collectors.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum(rate(otelcol_receiver_accepted_spans_total{pod=~\"${pod:regex}\"}[5m]))",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Metrics Received / s",
      "description": "Total metric points accepted per second across all collectors.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total{pod=~\"${pod:regex}\"}[5m]))",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Logs Received / s",
      "description": "Total log records accepted per second across all collectors.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum(rate(otelcol_receiver_accepted_log_records_total{pod=~\"${pod:regex}\"}[5m]))",
          "instant": true
        }
      ]
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Export Failures",
      "description": "Total data items that failed export across all signal types over the selected time range; any non-zero value warrants investigation.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "(\n  sum(increase(otelcol_exporter_send_failed_spans_total{pod=~\"${pod:regex}\"}[$__range])) or vector(0)\n) + (\n  sum(increase(otelcol_exporter_send_failed_metric_points_total{pod=~\"${pod:regex}\"}[$__range])) or vector(0)\n) + (\n  sum(increase(otelcol_exporter_send_failed_log_records_total{pod=~\"${pod:regex}\"}[$__range])) or vector(0)\n)",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 10,
      "title": "Traces",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Spans Received",
      "description": "Rate of spans accepted at the receiver per pod and receiver type.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
