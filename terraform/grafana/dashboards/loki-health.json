      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(loki_request_duration_seconds_bucket{job=\"monitoring/loki\", route!~\"ready|metrics|/grpc.health.v1.Health/Check\"}[$__rate_interval])))",
