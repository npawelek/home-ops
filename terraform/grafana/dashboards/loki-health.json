      },
      "description": "Rate of 4xx and 5xx responses by route and status code. Excludes health-check and self-scrape routes. 429 and 503 on otlp_v1_logs indicate ingestion back-pressure or rate limits. 500 on push routes signals internal ingester errors. 400 on otlp_v1_logs indicates malformed OTLP payloads from writers. An empty panel means no current errors.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
