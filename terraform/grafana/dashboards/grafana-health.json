      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum by (datasource, method) (rate(grafana_datasource_request_total{job=\"grafana\"}[$__rate_interval]))",
          "legendFormat": "{{datasource}} / {{method}}",
          "refId": "A"
        }
      ],
      "title": "Datasource Request Rate",
      "type": "timeseries"
