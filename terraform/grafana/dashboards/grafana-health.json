          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum by (status_code) (rate(grafana_http_request_duration_seconds_count{job=\"grafana\", status_code=~\"[45]..\"}[$__rate_interval]))",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Error Rate",
