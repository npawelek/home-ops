    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Rate of S3 API calls by operation. Healthy means steady request flow matching client activity. GetObject and PutObject dominate during active backup/restore; sustained high DeleteObjects may indicate aggressive cleanup cycles.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum by (api_endpoint) (rate(api_s3_request_counter_total{job=\"garage\"}[$__rate_interval]))",
          "legendFormat": "{{api_endpoint}}"
        }
      ],
      "title": "S3 Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Raw bytes read and written to the block store (NFS-backed). Reflects underlying storage activity from S3 operations. High write throughput with low S3 PUT rate typically indicates large multipart uploads in progress.",
