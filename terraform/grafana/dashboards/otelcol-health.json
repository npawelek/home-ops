      "title": "Logs Received / s",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Highest queue fill ratio across all exporter queues over time; threshold lines at 50% (yellow) and 80% (red) — approaching 1.0 means data loss is imminent.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "max(otelcol_exporter_queue_size{pod=~\"${pod:regex}\"} / otelcol_exporter_queue_capacity{pod=~\"${pod:regex}\"})",
          "legendFormat": "max fill ratio",
          "refId": "A"
