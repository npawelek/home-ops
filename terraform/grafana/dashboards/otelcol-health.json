{
  "uid": "otelcol-pipeline-health",
  "title": "OpenTelemetry Collector Health",
  "description": "Health, resource usage, throughput, backpressure, and error monitoring for agent and gateway OTel collectors",
  "tags": [
    "otelcol",
    "monitoring"
  ],
  "schemaVersion": 38,
  "refresh": "30s",
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "P4169E866C3094E38"
        },
        "definition": "label_values(otelcol_process_uptime_total, pod)",
        "includeAll": true,
        "label": "Pod",
        "multi": true,
        "name": "pod",
        "query": {
          "query": "label_values(otelcol_process_uptime_total, pod)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
