    {
      "datasource": {"type": "prometheus", "uid": "P4169E866C3094E38"},
      "description": "Rate at which authentication flows are being planned, by flow slug. Healthy values reflect active auth activity; spikes may indicate scanning or auth storms.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10, "lineWidth": 1, "showPoints": "never", "spanNulls": false},
          "unit": "reqps"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "P4169E866C3094E38"},
          "expr": "sum by (flow_slug) (rate(authentik_flows_plan_time_count{job=\"authentik-server-metrics\"}[$__rate_interval]))",
          "legendFormat": "{{flow_slug}}",
          "refId": "A"
        }
      ],
      "title": "Flow Planning Rate",
      "type": "timeseries"
    },
    {
