      },
      "id": 1,
      "title": "Rate",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Rate of reconciliation attempts per cert-manager controller per second. Healthy operation shows steady low-volume activity across active controllers (challenges, orders, certificates-*). A sustained spike on any controller may indicate a backlog of certificate requests or repeated issuer retries.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum by (controller) (rate(certmanager_controller_sync_call_count_total{job=\"cert-manager\"}[$__rate_interval]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "title": "Controller Sync Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Rate of sync errors per cert-manager controller per second. In a healthy cluster this is zero on all controllers. Non-zero values on challenges or orders indicate ACME DNS/HTTP challenge failures — check cert-manager logs and DNS resolver reachability. Non-zero values on issuers or clusterissuers indicate issuer configuration problems.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 10
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum by (controller) (rate(certmanager_controller_sync_error_count_total{job=\"cert-manager\"}[$__rate_interval]))",
          "legendFormat": "{{controller}}",
          "refId": "A"
        }
      ],
      "title": "Controller Sync Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Total sync errors across all controllers in the current rate interval. Green (0) means no sync failures are occurring. Red (≥1) means at least one controller is encountering errors — check the sync error rate timeseries panel to identify which controller.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "ceil(sum(increase(certmanager_controller_sync_error_count_total{job=\"cert-manager\"}[$__rate_interval]))) or vector(0)",
          "legendFormat": "errors",
          "refId": "A"
        }
      ],
      "title": "Sync Errors (window)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 6,
      "title": "State / Inventory",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Number of managed certificates that are not Ready. Green (0) means all certificates are valid. Red (≥1) means one or more certificates have failed — check cert-manager logs for ACME challenge or issuer errors. Scales to any number of certificates.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "count(certmanager_certificate_ready_status{job=\"cert-manager\", condition=\"True\"} == 0) or vector(0)",
          "legendFormat": "not ready",
          "refId": "A"
        }
      ],
      "title": "Certs Not Ready",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Readiness of each ClusterIssuer (condition=True gauge). Green (1) means the issuer is ready and able to sign certificates. Red (0) means the issuer is not ready — check Let's Encrypt API reachability or ACME account credentials.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "certmanager_clusterissuer_ready_status{job=\"cert-manager\", condition=\"True\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "title": "ClusterIssuer Readiness",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 9,
      "title": "Capacity",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Time remaining until each certificate expires, in days. cert-manager automatically renews certificates before expiry (at approximately 2/3 of the validity period), so values should not approach zero in normal operation. Threshold lines: orange at 7 days (renewal may be failing), red at 0 (cert has expired). If a cert drops below 7 days without being renewed, manual intervention is required.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 7
              },
              {
                "color": "green",
                "value": 30
              }
            ]
          },
          "unit": "d"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "(certmanager_certificate_expiration_timestamp_seconds{job=\"cert-manager\"} - time()) / 86400",
          "legendFormat": "{{name}} / {{exported_namespace}}",
          "refId": "A"
        }
      ],
      "title": "Days Until Certificate Expiry",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Time remaining until cert-manager attempts the next automatic renewal for each certificate, in days. cert-manager renews at approximately 2/3 of the validity period — for 90-day Let's Encrypt certs this is roughly 30 days before expiry. Negative values mean the renewal window has passed and renewal is in progress or overdue. Values approaching zero are expected and healthy when cert-manager renews on schedule.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": {
              "mode": "dashed"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          },
          "unit": "d"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "id": 11,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "(certmanager_certificate_renewal_timestamp_seconds{job=\"cert-manager\"} - time()) / 86400",
          "legendFormat": "{{name}} / {{exported_namespace}}",
          "refId": "A"
        }
      ],
      "title": "Days Until Next Renewal",
      "type": "timeseries"
    }
  ],
