      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "histogram_quantile(0.99, sum by (le, name) (rate(nfd_master_nodefeaturerule_processing_duration_seconds_bucket{job=\"kube-system/node-feature-discovery\"}[$__rate_interval])))",
          "legendFormat": "P99 {{name}}",
          "refId": "A"
        }
      ],
      "title": "NFD Rule Processing Duration (P99)",
      "type": "timeseries"
