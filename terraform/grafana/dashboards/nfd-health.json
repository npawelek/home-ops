    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Rate of node feature update requests received by the NFD master (leader replica only). 'Requests' counts all incoming gRPC requests from workers; 'Updates Applied' counts nodes where labels were actually changed. A gap between the two is normal when feature sets are stable — workers report periodically but label writes only occur when hardware or OS features change.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum(rate(nfd_master_node_update_requests_total{job=\"kube-system/node-feature-discovery\"}[$__rate_interval]))",
          "legendFormat": "Requests",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum(rate(nfd_master_node_updates_total{job=\"kube-system/node-feature-discovery\"}[$__rate_interval]))",
          "legendFormat": "Updates Applied",
          "refId": "B"
        }
      ],
      "title": "Node Update Requests/s",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "Rate at which the NFD garbage collector removes stale NodeFeature objects. The `kind` label identifies the object type (e.g. NodeFeature). A non-zero rate is expected when nodes join or leave the cluster or when worker pods restart. Sustained elevated deletion rate may indicate worker restart loops.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "sum by (kind) (rate(nfd_gc_objects_deleted_total{job=\"kube-system/node-feature-discovery\"}[$__rate_interval]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ],
      "title": "GC Objects Deleted/s",
      "type": "timeseries"
    },
