    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "P99 and P50 latency for the NFD worker's full feature discovery cycle per node — the time taken to interrogate all hardware and OS feature sources (CPU, PCI, kernel, USB, etc.). Each line is one node. P99 > 500ms may indicate a slow probe source on that node. Use the Node variable to zoom into a specific node.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "histogram_quantile(0.99, sum by (le, node) (rate(nfd_worker_feature_discovery_duration_seconds_bucket{job=\"kube-system/node-feature-discovery\", node=~\"$node\"}[$__rate_interval])))",
          "legendFormat": "P99 {{node}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P4169E866C3094E38"
          },
          "expr": "histogram_quantile(0.50, sum by (le, node) (rate(nfd_worker_feature_discovery_duration_seconds_bucket{job=\"kube-system/node-feature-discovery\", node=~\"$node\"}[$__rate_interval])))",
          "legendFormat": "P50 {{node}}",
          "refId": "B"
        }
      ],
      "title": "Worker Feature Discovery Duration",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "P4169E866C3094E38"
      },
      "description": "P99 latency for the NFD master to evaluate each NodeFeatureRule CR against all nodes. The `name` label identifies the rule — rules in this cluster are the GPU detection rules (amd-radeon, intel-arc, intel-i915, intel-xe-igpu). Values are normally in the microsecond–millisecond range. Spikes indicate a complex rule or elevated node count.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "s"
        },
        "overrides": []
      },
