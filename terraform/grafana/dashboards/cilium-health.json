{
  "uid": "cilium-health",
  "title": "Cilium Health",
  "tags": ["cilium", "network", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
        "query": "label_values(cilium_version{job=\"cilium-agent\"}, node)",
        "allValue": ".+",
        "includeAll": true,
        "multi": true,
        "hide": 0,
        "options": [],
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Rate",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Packet Forward Rate",
      "description": "Packets successfully forwarded per second by node and direction.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum by (node, direction) (rate(cilium_forward_count_total{node=~\"$node\"}[$__rate_interval]))",
          "legendFormat": "{{node}} / {{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Packet Drop Rate (excl. VLAN filter noise)",
      "description": "Dropped packets per second by node and reason. 'VLAN traffic disallowed by VLAN filter' excluded — expected noise from Talos VLAN configuration.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum by (node, reason) (rate(cilium_drop_count_total{node=~\"$node\",reason!=\"VLAN traffic disallowed by VLAN filter\"}[$__rate_interval]))",
          "legendFormat": "{{node}} / {{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "row",
      "title": "Errors",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Controllers Failing",
      "description": "Cilium controllers in a failing state. Non-zero means a stuck reconciliation loop — investigate immediately.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum(cilium_controllers_failing{node=~\"$node\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Unreachable Nodes",
      "description": "Nodes that cilium-agent cannot reach. Non-zero indicates cluster split-brain or node isolation.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "max(cilium_unreachable_nodes{node=~\"$node\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Endpoints Ready",
      "description": "Total endpoints in ready state across selected nodes.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum(cilium_endpoint_state{node=~\"$node\",endpoint_state=\"ready\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Total Endpoints",
      "description": "Total endpoint count across selected nodes.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum(cilium_endpoint{node=~\"$node\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Policy Denied Drop Rate",
      "description": "Packets dropped due to Cilium network policy denial by node and direction. Sustained rate indicates unexpected traffic being actively blocked.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum by (node, direction) (rate(cilium_drop_count_total{node=~\"$node\",reason=\"Policy denied\"}[$__rate_interval]))",
          "legendFormat": "{{node}} / {{direction}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Agent Error & Warning Rate",
      "description": "Cilium agent error and warning log events per second by node and level. Sustained error rate warrants log inspection.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum by (node, level) (rate(cilium_errors_warnings_total{node=~\"$node\"}[$__rate_interval]))",
          "legendFormat": "{{node}} / {{level}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "row",
      "title": "Duration",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Endpoint Regeneration P99 / P50",
      "description": "Time to regenerate a Cilium endpoint (apply policy changes) by node. P99 spikes indicate slow policy propagation — check for BPF map pressure or API server latency.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "histogram_quantile(0.99, sum by (le, node) (rate(cilium_endpoint_regeneration_time_stats_seconds_bucket{node=~\"$node\",scope=\"total\"}[$__rate_interval])))",
          "legendFormat": "p99 / {{node}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "histogram_quantile(0.50, sum by (le, node) (rate(cilium_endpoint_regeneration_time_stats_seconds_bucket{node=~\"$node\",scope=\"total\"}[$__rate_interval])))",
          "legendFormat": "p50 / {{node}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Inter-node Connectivity Latency P99",
      "description": "P99 Cilium health-check probe latency between nodes by type. Rising latency indicates network path degradation between specific node pairs.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "histogram_quantile(0.99, sum by (le, node, type) (rate(cilium_node_health_connectivity_latency_seconds_bucket{node=~\"$node\"}[$__rate_interval])))",
          "legendFormat": "p99 / {{node}} / {{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Saturation",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "BPF Map Pressure",
      "description": "BPF kernel map fill ratio (0–1) by map type and node. Above 0.7 warrants attention. At 1.0 Cilium silently drops packets with no other signal — this panel is the only early warning.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "max by (map_name, node) (cilium_bpf_map_pressure{node=~\"$node\"})",
          "legendFormat": "{{node}} / {{map_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Endpoint State Distribution",
      "description": "Count of endpoints in each state per node. All should remain in 'ready'. Sustained non-zero counts in regenerating/waiting/restoring indicate stuck endpoints.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* / ready$" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* / regenerating$" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* / (waiting-for-identity|waiting-to-regenerate|restoring|disconnecting)$" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "sum by (node, endpoint_state) (cilium_endpoint_state{node=~\"$node\"})",
          "legendFormat": "{{node}} / {{endpoint_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "type": "row",
      "title": "IPAM",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "IPAM Pool Capacity",
      "description": "Total IP address slots in the IPAM pool per node (kubernetes IPAM mode — reflects pod CIDR size). A sustained decline indicates pool reconfiguration or exhaustion risk. Threshold lines at 30 and 10 remaining.",
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": false,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
          "expr": "cilium_ipam_capacity{node=~\"$node\"}",
          "legendFormat": "{{node}}",
          "refId": "A"
        }
      ]
    }
  ]
}
