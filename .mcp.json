{
  "mcpServers": {
    "grafana": {
      "command": "mise",
      "args": [
        "x",
        "--",
        "mcp-compressor",
        "{\"mcpServers\":{\"grafana\":{\"command\":\"mcp-grafana\",\"args\":[\"--disable-incident\",\"--disable-alerting\",\"--disable-sift\",\"--disable-oncall\"]}}}"
      ]
    },
    "home-assistant": {
      "type": "stdio",
      "command": "mise",
      "args": [
        "x",
        "--",
        "ha-mcp"
      ]
    }
  }
}
